generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum EventStatus {
  INQUIRY
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(STAFF)

  createdEvents Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id             String       @id @default(cuid())
  clientName     String
  clientEmail    String
  clientPhone    String?
  eventDate      DateTime
  venueName      String
  venueAddress   String
  guestCount     Int
  notes          String?
  status         EventStatus @default(INQUIRY)

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}